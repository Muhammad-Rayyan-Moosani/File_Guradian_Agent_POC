# ─────────────────────────────────────────────────────────────────────────
# File Guardian Agent — environment template.
# Copy this file to ".env" (same folder) and fill in the real values.
# The real .env is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────

# --- Database (local SQLite) -----------------------------------------------
# The app stores everything in a single local SQLite file — no cloud needed.
# By default it lives at backend/file_guardian.db. Override the location only
# if you want the data somewhere specific (e.g. a dedicated data folder).
# FG_DB_PATH=C:\FileGuardian\data\file_guardian.db

# --- Anthropic (optional: AI summaries; template fallback works without it)
ANTHROPIC_API_KEY=

# --- Email notifications (Gmail SMTP) --------------------------------------
# Leave SMTP_* blank to run notifications in safe "log-only" mode.
# To send real mail through Gmail (see the setup steps in the README):
#   1. Turn on 2-Step Verification on the Google account.
#   2. Create an "App password" (Google Account -> Security -> App passwords).
#   3. Put the 16-character app password (no spaces) in SMTP_PASSWORD below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-address@gmail.com

# --- Tuning (sensible defaults; override only if you need to) ---------------
# How many files can be validated at the same time.
FG_WORKERS=4
# Read huge CSVs this many rows at a time (keeps memory flat on big files).
FG_CHUNK_ROWS=100000
# Reject any single file larger than this many megabytes (0 = no limit).
FG_MAX_FILE_MB=0
# Re-scan active profiles' inbound folders this often (seconds) so new/edited
# profiles are picked up without restarting the app.
FG_REFRESH_SECONDS=15
